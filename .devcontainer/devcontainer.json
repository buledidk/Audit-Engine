{
  "name": "AuditEngine v10 AURA",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [5173, 3001, 5432],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" },
    "3001": { "label": "Express API", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },
  "postCreateCommand": "npm ci && pip install -r scripts/python-audit-engine/requirements.txt",
  "postStartCommand": "npm run dev",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "files.trimTrailingWhitespace": true,
        "javascript.preferences.quoteStyle": "single",
        "emmet.includeLanguages": { "javascript": "javascriptreact" }
      },
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-python.python",
        "ms-vscode.vscode-json",
        "formulahendry.auto-rename-tag",
        "streetsidesoftware.code-spell-checker",
        "eamodio.gitlens"
      ]
    },
    "codespaces": {
      "openFiles": ["src/AuditEngine_AURA.jsx", "src/router.jsx"]
    }
  },
  "remoteEnv": {
    "VITE_APP_ENV": "development",
    "VITE_APP_VERSION": "10.0.0",
    "VITE_APP_NAME": "AuditEngine AURA"
  }
}
