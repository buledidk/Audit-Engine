# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT CONFIGURATION
# AuditEngine v2026.1 - Enterprise Audit Automation Platform
# ═══════════════════════════════════════════════════════════════════════════

# ENVIRONMENT
NODE_ENV=production
VITE_ENV=production
DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════
# AI MODEL CONFIGURATION (Multi-Model Strategy)
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic Claude (PRIMARY)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.2

# OpenAI GPT-4 (SECONDARY)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=8000
OPENAI_TEMPERATURE=0.3

# Ollama Local (FALLBACK)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.5

# Agent Framework Configuration
AGENT_MODEL=claude-3-5-sonnet-20241022
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.2
AGENT_TIMEOUT=30000
AGENT_RETRY_ATTEMPTS=3
AGENT_RETRY_DELAY=1000
AGENT_LOG_FILE=./logs/agent-operations.log

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Supabase PostgreSQL
VITE_SUPABASE_URL=https://mbvjtondgunckgzrmyhq.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:password@localhost:5432/audit_engine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=audit_engine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_password_here
REDIS_DB=0
REDIS_TTL=3600

# ═══════════════════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY
# ═══════════════════════════════════════════════════════════════════════════

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-production
JWT_EXPIRY=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=auditengine
JWT_AUDIENCE=auditengine-users

# Session Management
SESSION_SECRET=your-super-secret-session-key-min-32-chars-long-production
SESSION_MAX_AGE=86400000

# API Security
API_KEY_HEADER=X-API-Key
CORS_ORIGIN=https://auditengine.vercel.app,https://yourdomain.com
CORS_CREDENTIALS=true
HELMET_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# EXTERNAL SERVICE INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
SLACK_CHANNELS_AUDITS=#audits
SLACK_CHANNELS_FINDINGS=#findings
SLACK_CHANNELS_DEPLOYMENTS=#deployments

# GitHub Integration
GITHUB_TOKEN=ghp_your-github-personal-access-token-here
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here
GITHUB_REPO=buledidk/Audit-Automation-Engine
GITHUB_OWNER=buledidk

# Email Configuration
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@auditengine.com
SENDGRID_FROM_NAME=AuditEngine
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
SMTP_FROM=noreply@auditengine.com
SMTP_TLS=true

# ═══════════════════════════════════════════════════════════════════════════
# AWS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# AWS S3 (File Storage)
VITE_AWS_REGION=eu-west-2
VITE_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
VITE_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
VITE_AWS_S3_BUCKET=audit-engine-files
AWS_S3_ENDPOINT=https://s3.eu-west-2.amazonaws.com
AWS_S3_VERSIONING=true
AWS_S3_ENCRYPTION=AES256

# AWS CloudWatch
AWS_CLOUDWATCH_ENABLED=true
AWS_CLOUDWATCH_LOG_GROUP=/aws/auditengine/production
AWS_CLOUDWATCH_NAMESPACE=AuditEngine

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION URLS
# ═══════════════════════════════════════════════════════════════════════════

# Application URLs
VITE_APP_URL=https://auditengine.vercel.app
VITE_API_URL=https://api.auditengine.vercel.app
VITE_WS_URL=wss://ws.auditengine.vercel.app
BACKEND_URL=http://localhost:3001
WEBHOOK_URL=https://api.auditengine.vercel.app/webhooks

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS & SETTINGS
# ═══════════════════════════════════════════════════════════════════════════

# Feature Flags
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_REAL_TIME_SYNC=true
FEATURE_OFFLINE_MODE=true
FEATURE_AI_AGENTS=true
FEATURE_EXTERNAL_INTEGRATIONS=true
FEATURE_WORKFLOW_AUTOMATION=true
FEATURE_ADVANCED_REPORTING=true

# Audit Settings
AUDIT_USER_ID=system
AUDIT_LOG_LEVEL=detailed
AUDIT_RETENTION_DAYS=2555

# Performance
CACHE_ENABLED=true
COMPRESSION_ENABLED=true
MINIFY_ASSETS=true
OPTIMIZE_IMAGES=true

# ═══════════════════════════════════════════════════════════════════════════
# MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════════

# Sentry Error Tracking (Optional)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application Insights
APP_INSIGHTS_KEY=00000000-0000-0000-0000-000000000000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_FILE=./logs/application.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYMENT & HOSTING
# ═══════════════════════════════════════════════════════════════════════════

# Vercel Configuration
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxx
VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxx
VERCEL_TOKEN=VercelAuthToken123456789

# Docker Configuration
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=auditengine
DOCKER_IMAGE_TAG=latest
DOCKER_REGISTRY_USERNAME=yourusername
DOCKER_REGISTRY_PASSWORD=yourpassword

# ═══════════════════════════════════════════════════════════════════════════
# COMPLIANCE & REGULATORY
# ═══════════════════════════════════════════════════════════════════════════

# GDPR Compliance
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=2555
GDPR_RIGHT_TO_BE_FORGOTTEN=true
GDPR_DATA_EXPORT_FORMAT=json

# Audit Standards
ISA_STANDARDS_ENABLED=true
REGIONAL_COMPLIANCE_ENABLED=true
UK_FCA_COMPLIANCE=true
EU_GDPR_COMPLIANCE=true

# Data Encryption
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_ROTATION_DAYS=90
DATA_CLASSIFICATION_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# INTEGRATIONS (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Microsoft Teams (Optional)
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/...
TEAMS_CHANNEL_ID=channel-id

# Atlassian Jira (Optional)
JIRA_API_TOKEN=your-jira-api-token
JIRA_INSTANCE_URL=https://yourinstance.atlassian.net
JIRA_PROJECT_KEY=AUDIT

# Slack App (Extended)
SLACK_OAUTH_TOKEN=xoxp-your-oauth-token
SLACK_OAUTH_USER_TOKEN=xoxp-your-user-token

# Zapier (Optional)
ZAPIER_API_KEY=your-zapier-api-key

# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Batch Processing
BATCH_SIZE=100
BATCH_TIMEOUT=30000
BATCH_RETRY_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_CLEANUP_INTERVAL=600000

# Concurrency
MAX_CONCURRENT_TASKS=10
MAX_CONCURRENT_API_CALLS=5
TASK_QUEUE_SIZE=1000

# Timeouts
API_TIMEOUT=30000
DATABASE_TIMEOUT=10000
EXTERNAL_SERVICE_TIMEOUT=20000

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY TOKENS & KEYS (KEEP SECURE!)
# ═══════════════════════════════════════════════════════════════════════════

# Note: All tokens above should be replaced with actual production values
# NEVER commit real tokens to version control
# Use Vercel Secrets or similar secure key management

# Encryption Master Key (keep safe)
MASTER_ENCRYPTION_KEY=your-master-encryption-key-min-32-chars-safe

# API Keys for monitoring/alerting
HEALTH_CHECK_TOKEN=your-health-check-token-here
ADMIN_API_KEY=your-admin-api-key-here
