# ═══════════════════════════════════════════════════════════════════════════════
# AuditEngine Production Environment Configuration
# Version: 2026.1
# Last Updated: March 20, 2026
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
VITE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Supabase Configuration (PostgreSQL Database)
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://mbvjtondgunckgzrmyhq.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
POSTGRES_URL=postgresql://postgres:[password]@db.mbvjtondgunckgzrmyhq.supabase.co:5432/postgres
POSTGRES_PRISMA_URL=postgresql://postgres:[password]@db.mbvjtondgunckgzrmyhq.supabase.co:5432/postgres?schema=public
POSTGRES_URL_NON_POOLING=postgresql://postgres:[password]@db.mbvjtondgunckgzrmyhq.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────────────────────
# Claude API Configuration (AI Services)
# ─────────────────────────────────────────────────────────────────────────────
VITE_CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY_HERE
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.7

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3 Configuration (File Storage)
# ─────────────────────────────────────────────────────────────────────────────
VITE_AWS_REGION=eu-west-2
VITE_AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
VITE_AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
VITE_AWS_S3_BUCKET=audit-engine-files-prod
AWS_S3_ENDPOINT=https://s3.eu-west-2.amazonaws.com
AWS_S3_FORCE_PATH_STYLE=false

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication Configuration
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE_MIN_32_CHARS
JWT_EXPIRY=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=auditengine-v2026.1
JWT_AUDIENCE=https://auditengine.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Redis Configuration (Caching)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_IF_NEEDED
REDIS_DB=0
CACHE_TTL=3600

# ─────────────────────────────────────────────────────────────────────────────
# Slack Integration Configuration
# ─────────────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-YOUR_SLACK_BOT_TOKEN_HERE
SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET_HERE
SLACK_APP_TOKEN=xapp-YOUR_SLACK_APP_TOKEN_HERE
SLACK_CHANNEL_ALERTS=C123456789
SLACK_CHANNEL_DEPLOYMENTS=C987654321

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Integration Configuration
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
GITHUB_REPO=buledidk/Audit-Engine
GITHUB_OWNER=buledidk
GITHUB_WEBHOOK_SECRET=YOUR_GITHUB_WEBHOOK_SECRET_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Email Configuration (SendGrid)
# ─────────────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@auditengine.co.uk
SENDGRID_FROM_NAME=AuditEngine Platform
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Vercel Deployment Configuration
# ─────────────────────────────────────────────────────────────────────────────
VERCEL_ORG_ID=YOUR_VERCEL_ORG_ID
VERCEL_PROJECT_ID=YOUR_VERCEL_PROJECT_ID
VERCEL_TOKEN=YOUR_VERCEL_TOKEN_HERE
VERCEL_GIT_REPO_SLUG=buledidk/Audit-Engine
VERCEL_GIT_PROVIDER=github

# ─────────────────────────────────────────────────────────────────────────────
# Security Configuration
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://auditengine.vercel.app,https://www.auditengine.co.uk
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
SECURE_HEADERS=true
HELMET_ENABLED=true
CSP_ENABLED=true
X_FRAME_OPTIONS=DENY

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring & Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
LOG_LEVEL=info
DEBUG=false
ENABLE_METRICS=true
METRICS_PORT=9090

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────
FEATURE_OFFLINE_SYNC=true
FEATURE_REAL_TIME_COLLABORATION=true
FEATURE_AI_NARRATIVES=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_MULTI_LANGUAGE=false
FEATURE_MOBILE_APP=false

# ─────────────────────────────────────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────────────────────────────────────
APP_URL=https://auditengine.vercel.app
API_BASE_URL=https://auditengine.vercel.app/api
FRONTEND_URL=https://auditengine.vercel.app
DOCS_URL=https://auditengine.vercel.app/docs

# ─────────────────────────────────────────────────────────────────────────────
# Database Backup Configuration
# ─────────────────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true

# ─────────────────────────────────────────────────────────────────────────────
# Cron Jobs Configuration
# ─────────────────────────────────────────────────────────────────────────────
CRON_SYNC_ENABLED=true
CRON_SYNC_INTERVAL=6h
CRON_BACKUP_ENABLED=true
CRON_BACKUP_INTERVAL=24h
CRON_CLEANUP_ENABLED=true
CRON_CLEANUP_INTERVAL=7d

# ═══════════════════════════════════════════════════════════════════════════════
# Notes:
# - Replace all "YOUR_*" placeholders with actual values
# - Never commit actual secrets to git - use Vercel Environment Variables
# - For Vercel: Set environment variables in Vercel Dashboard
# - For Docker: Use docker-compose.yml with .env.production
# - All timestamps are in UTC
# ═══════════════════════════════════════════════════════════════════════════════
