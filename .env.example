# ═══════════════════════════════════════════════════════════════════
# AuditEngine Environment Configuration
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# SUPABASE (Phase 2 - Database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SUPABASE SERVER (Phase 2 - Server-side, NO VITE_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
JWT_SECRET=your-jwt-secret-for-legacy-auth

# AWS S3 (Phase 2 - File Storage)
VITE_AWS_REGION=eu-west-2
VITE_AWS_ACCESS_KEY_ID=your-access-key
VITE_AWS_SECRET_ACCESS_KEY=your-secret-key
VITE_AWS_S3_BUCKET=audit-engine-files

# CLAUDE API (Phase 3 - AI Integration)
VITE_CLAUDE_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# APPLICATION
VITE_APP_ENV=development
VITE_APP_NAME=AuditEngine
VITE_APP_VERSION=10.0.0
VITE_APP_URL=https://auditengine.agency

# SERVER (Express backend)
JWT_SECRET=your-jwt-secret-here
CORS_ORIGIN=https://auditengine.agency

# SLACK INTEGRATION
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_DEFAULT_CHANNEL=#audit-engine
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# GITHUB INTEGRATION
GITHUB_TOKEN=ghp_your-github-token
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# EMAIL (SendGrid or SMTP)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@auditengine.agency
SENDGRID_FROM_NAME=AuditEngine

# DATABASE (for migration runner)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audit_automation
DB_USER=postgres
DB_PASSWORD=your-db-password
