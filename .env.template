# ╔════════════════════════════════════════════════════════════════════════╗
# ║           AUDIT AUTOMATION ENGINE - PRODUCTION CONFIG TEMPLATE          ║
# ║                      Copy to .env and fill in values                    ║
# ╚════════════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════════════
# 1. APPLICATION ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=3001
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3001

# ═══════════════════════════════════════════════════════════════════════════
# 2. AI MODELS - PRIMARY (Claude - Anthropic)
# ═══════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE
VITE_CLAUDE_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.2

# ═══════════════════════════════════════════════════════════════════════════
# 3. AI MODELS - SECONDARY (OpenAI - GPT-4)
# ═══════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=8000
OPENAI_TEMPERATURE=0.3

# ═══════════════════════════════════════════════════════════════════════════
# 4. AI MODELS - FALLBACK (Ollama - Local Open Source)
# ═══════════════════════════════════════════════════════════════════════════
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.5

# ═══════════════════════════════════════════════════════════════════════════
# 5. DATABASE - PostgreSQL
# ═══════════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:password@localhost:5432/audit_engine
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=audit_engine

# ═══════════════════════════════════════════════════════════════════════════
# 6. CACHE - Redis
# ═══════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# 7. SLACK CONNECTOR
# ═══════════════════════════════════════════════════════════════════════════
SLACK_BOT_TOKEN=xoxb-YOUR_SLACK_BOT_TOKEN_HERE
SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET_HERE
SLACK_AUDIT_CHANNEL=#audits
SLACK_FINDINGS_CHANNEL=#findings
SLACK_DEPLOYMENTS_CHANNEL=#deployments

# ═══════════════════════════════════════════════════════════════════════════
# 8. GITHUB CONNECTOR
# ═══════════════════════════════════════════════════════════════════════════
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
GITHUB_WEBHOOK_SECRET=YOUR_GITHUB_WEBHOOK_SECRET_HERE
GITHUB_REPO_OWNER=buledidk
GITHUB_REPO_NAME=Audit-Engine
GITHUB_BRANCH=main

# ═══════════════════════════════════════════════════════════════════════════
# 9. EMAIL CONNECTOR - SendGrid (Primary)
# ═══════════════════════════════════════════════════════════════════════════
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@auditengine.com
SENDGRID_FROM_NAME=Audit Engine

# ═══════════════════════════════════════════════════════════════════════════
# 10. EMAIL CONNECTOR - SMTP (Fallback)
# ═══════════════════════════════════════════════════════════════════════════
SMTP_PROVIDER=sendgrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.YOUR_SENDGRID_API_KEY_HERE
SMTP_FROM_EMAIL=noreply@auditengine.com
SMTP_FROM_NAME=Audit Engine

# ═══════════════════════════════════════════════════════════════════════════
# 11. AWS CONNECTOR
# ═══════════════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=audit-engine-files
AWS_CLOUDWATCH_NAMESPACE=AuditEngine
AWS_CLOUDWATCH_LOG_GROUP=/aws/lambda/audit-engine

# ═══════════════════════════════════════════════════════════════════════════
# 12. SECURITY & AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════
JWT_SECRET=YOUR_JWT_SECRET_KEY_MIN_32_CHARS_LONG_HERE
SESSION_SECRET=YOUR_SESSION_SECRET_KEY_MIN_32_CHARS_LONG_HERE
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ═══════════════════════════════════════════════════════════════════════════
# 13. LOGGING & DEBUG
# ═══════════════════════════════════════════════════════════════════════════
DEBUG=audit:*
LOG_LEVEL=info
ENABLE_AUDIT_TRAIL=true
ENABLE_COMPLIANCE_CHECKS=true
ENABLE_AI_AGENTS=true
ENABLE_WORKER_QUEUE=true
SENTRY_DSN=https://YOUR_SENTRY_DSN_HERE

# ═══════════════════════════════════════════════════════════════════════════
# 14. FILE UPLOAD & STORAGE
# ═══════════════════════════════════════════════════════════════════════════
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,docx,xlsx,csv,txt,jpg,png,zip

# ═══════════════════════════════════════════════════════════════════════════
# 15. COMPLIANCE & GDPR
# ═══════════════════════════════════════════════════════════════════════════
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=365
COMPLIANCE_FRAMEWORK=ISA
ENABLE_COMPLIANCE_PLUGINS=true

# ═══════════════════════════════════════════════════════════════════════════
# 16. WEBSOCKET & REAL-TIME
# ═══════════════════════════════════════════════════════════════════════════
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30000
WEBSOCKET_PING_TIMEOUT=5000

# ═══════════════════════════════════════════════════════════════════════════
# 17. PERFORMANCE & OPTIMIZATION
# ═══════════════════════════════════════════════════════════════════════════
AGENT_CACHE_TTL=300
AGENT_CACHE_MAX_SIZE=1000
AGENT_EXECUTION_TIMEOUT=30000
AGENT_RETRY_ATTEMPTS=3
AGENT_RETRY_DELAY=1000

# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# ═══════════════════════════════════════════════════════════════════════════
# 1. Copy this file to .env
# 2. Fill in all YOUR_* placeholders with actual values
# 3. For development, use localhost URLs
# 4. For production, use actual domain/service endpoints
# 5. NEVER commit .env file to git - use .env.template
# 6. For staging, create .env.staging with staging endpoints
# 7. For Docker, use environment variables instead of .env file
# 8. Run: npm run verify-env to validate all required vars are set
# ═══════════════════════════════════════════════════════════════════════════
