{
      "version": 2,
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "vite",
      "installCommand": "npm ci",

      "regions": ["cdg", "lhr", "sfo"],

      "rewrites": [
              {
                        "source": "/(.*)",
                        "destination": "/index.html"
              }
      ],

      "headers": [
              {
                        "source": "/assets/:path*",
                        "headers": [
                                    {
                                                  "key": "Cache-Control",
                                                  "value": "public, max-age=31536000, immutable"
                                    }
                        ]
              }
      ],

      "github": {
              "enabled": true,
              "silent": false,
              "autoAlias": true,
              "autoJobCancelation": true
      },

      "cleanUrls": true,
      "trailingSlash": false
}
