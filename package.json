{
  "name": "auditengine",
  "version": "10.0.0",
  "description": "AuditEngine — Unified Professional Audit Automation Platform (AURA)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --open",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "progress": "node scripts/progress-tracker.js report",
    "progress:init": "node scripts/progress-tracker.js init",
    "progress:add": "node scripts/progress-tracker.js add",
    "progress:start": "node scripts/progress-tracker.js start",
    "progress:complete": "node scripts/progress-tracker.js complete",
    "progress:reset": "node scripts/progress-tracker.js reset",
    "build:track": "node scripts/progress-tracker.js build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{js,jsx}' 'server/**/*.js'",
    "format:check": "prettier --check 'src/**/*.{js,jsx}' 'server/**/*.js'",
    "type-check": "echo 'Note: Project uses JavaScript/JSX, TypeScript checking skipped'",
    "check:all": "npm run lint && npm run build",
    "agent-monitor": "node src/agents/cli-tool.js --monitor",
    "agents": "node --env-file-if-exists=.env.local src/agents/cli-tool.js",
    "agents:plan": "node --env-file-if-exists=.env.local src/agents/cli-tool.js plan",
    "agents:review": "node --env-file-if-exists=.env.local src/agents/cli-tool.js review",
    "agents:security": "node --env-file-if-exists=.env.local src/agents/cli-tool.js security-audit",
    "agents:compliance": "node --env-file-if-exists=.env.local src/agents/cli-tool.js compliance-audit",
    "agents:docs": "node --env-file-if-exists=.env.local src/agents/cli-tool.js docs",
    "agents:test": "node --env-file-if-exists=.env.local src/agents/cli-tool.js test-analysis",
    "agents:report": "node --env-file-if-exists=.env.local src/agents/cli-tool.js report",
    "deploy:db": "node scripts/deploy-database.js",
    "deploy:db:seed": "node scripts/deploy-database.js --seed-only",
    "deploy:db:admin": "node scripts/deploy-database.js --admin-only",
    "deploy:db:sql": "node scripts/deploy-database.js --sql-only",
    "dashboard": "node scripts/unified-orchestrator-dashboard.js",
    "start:engine": "node scripts/start-engine.js",
    "start:watchdog": "node scripts/start-watchdog.js",
    "verify:prod": "node scripts/verify-prod.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-cloudwatch": "^3.1014.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "mathjs": "^15.1.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "pdfmake": "^0.3.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "pg": "^8.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.0-beta.13",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
